# Copy to .env for local development.

# Required in production. Empty disables auth (dev-only).
APP_PASSWORD=

# Used to sign the session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-insecure-secret-change-me

# Required for /insights and /ask features. Optional in dev.
OPENAI_API_KEY=

# SQLite path. On Fly this is /data/golf_scorecards.db (volume mount).
DB_PATH=data/golf_scorecards.db

APP_ENV=development
DEBUG=true
